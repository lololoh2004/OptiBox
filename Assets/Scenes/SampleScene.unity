    m_PersistentCalls:
      m_Calls: []
  m_text: "local sensitivity = 0.15\nlocal curPitch = 0\nlocal curYaw = 0\n\nlocal
    cam = Entity(\"Main Camera\")\n\nfunction Think()\n    if cam then\n        local
    dx = GetMouseX() * sensitivity\n        local dy = GetMouseY() * sensitivity\n\n       
    curYaw = curYaw + dx\n        curPitch = curPitch - dy\n        \n        if
    curPitch > 89 then curPitch = 89 end\n        if curPitch < -89 then curPitch
    = -89 end\n\n        SetAngles(cam, curPitch, curYaw, 0)\n    end\nend\n\u200B"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
